checkpoints/
outputs/**
# Allow negated patterns inside outputs/ (parent dirs must be un-ignored first)
!outputs/**/
!outputs/**/.gitkeep
!outputs/**/*.png
!outputs/**/*.log
# Keep smoke / scratch runs out of version control (logs would otherwise match above)
outputs/local_smoke/
outputs/post_pull_smoke/
logs/
data/

# OS / local clutter
.DS_Store
.mplconfig/

# Dataset roots (large; user-specific paths)
LEVIR CD/

# Cluster / SLURM one-off outputs
train_*.out

# Never commit SSH / key material (see docs/SECURITY.md)
ssh-copy-id*
*ssh-copy-id*
*.pem
*.key
__pycache__/
.pytest_cache/
*.egg-info/
.venv/
*.pyc
.ipynb_checkpoints/
*.pt
*.pth
# Allow merged CIFAR ablation summary to be versioned (small dict checkpoint)
!outputs/ablations/all_ablation_results.pt
!outputs/ablations/ablation_summary.csv
venv/
processed_oscd/
